<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/js/all.min.js"></script>
</head>
<body class="portfolio">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="index.html">My Portfolio</a>
        </div>
    </nav>

    <div class="container my-5">
        <h1>My Work <i class="fas fa-briefcase"></i></h1>
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-code"></i> To-Do List App</h5>
                        <p class="card-text"> A basic task manager where users can add, mark as completed, and delete tasks. It helps showcase JavaScript event handling and DOM manipulation.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-laptop"></i> Random Quote Generator</h5>
                        <p class="card-text">Displays a random motivational quote when a button is clicked. This highlights arrays, functions, and user interaction with JavaScript.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-database"></i> Simple Calculator</h5>
                        <p class="card-text">A basic calculator that performs addition, subtraction, multiplication, and division. This demonstrates input handling, conditionals, and basic arithmetic operations in JavaScript.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-4 bg-dark text-light mt-5">
        <p>&copy; 2025 My Portfolio</p>
    </footer>
</body>
</html>

